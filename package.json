{
  "name": "anno117-translator",
  "displayName": "Anno 117 Translator",
  "description": "Use DeepL to translate your Anno 117 mod's English-language XML file into all the other languages used by the game.",
  "version": "1.0.0",
  "publisher": "Taludas",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
    "repository": {
    "type": "git",
    "url": "https://github.com/Taludas/Anno-117-Translator"
  },
  "activationEvents": [
    "onCommand:anno117.translateXml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "anno117.translateXml",
        "title": "Translate texts_english.xml"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Anno 117 Translator Settings",
      "properties": {
        "anno117translator.deepLApiKey": {
          "type": "string",
          "default": "",
          "description": "Your personal DeepL API key"
        },
        "anno117translator.batchDelay": {
          "type": "number",
          "default": 250,
          "description": "Delay per batch in milliseconds (to avoid DeepL rate limits)"
        },
        "anno117translator.overwriteExisting": {
          "type": "boolean",
          "default": false,
          "description": "Overwrite existing language files automatically without prompting"
        }
      }
    },
    "keybindings": [
      {
        "command": "anno117.translateXml",
        "key": "ctrl+alt+t",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -watch -p ./",
    "postinstall": "node ./node_modules/vscode/bin/install"
  },
  "devDependencies": {
    "typescript": "^5.1.0",
    "vscode": "^1.80.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}